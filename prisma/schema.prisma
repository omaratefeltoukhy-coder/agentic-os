// GulfPaws — Pet care booking marketplace for the Gulf region
// Prisma schema. Models beyond auth/users are scaffolded now so later
// build steps (onboarding, booking engine, payments, growth, admin)
// don't require destructive migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  CAREGIVER
  ADMIN
}

enum GulfCity {
  DUBAI
  ABU_DHABI
  RIYADH
  JEDDAH
  DOHA
  KUWAIT_CITY
  MANAMA
  MUSCAT
}

enum Currency {
  AED
  SAR
  QAR
  KWD
  BHD
  OMR
}

enum ServiceType {
  DOG_WALKING
  CAT_SITTING
  PET_BOARDING
  GROOMING
  PET_TAXI
  VET_VISIT
}

enum Language {
  ARABIC
  ENGLISH
  HINDI
  URDU
  TAGALOG
  FRENCH
}

enum PetType {
  DOG
  CAT
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  DECLINED
  IN_PROGRESS
  COMPLETED
  REVIEWED
  CANCELLED_BY_OWNER
  CANCELLED_BY_CAREGIVER
  AUTO_DECLINED
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  CASH
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  OWNER_PLUS
  CAREGIVER_PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

// ---------------------------------------------------------------------------
// Auth (NextAuth / Auth.js) — Prisma adapter models
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// A short-lived numeric OTP used for email verification / passwordless steps.
model OtpCode {
  id         String    @id @default(cuid())
  email      String
  code       String
  purpose    String // "EMAIL_VERIFY" | "PASSWORD_RESET"
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

// ---------------------------------------------------------------------------
// User & roles
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String? // null for OAuth-only accounts
  image         String?

  phoneCountryCode String? // +971, +966, +974, +965, +973, +968
  phoneNumber      String?
  whatsappOptIn    Boolean @default(false)

  roles           Role[]  @default([OWNER])
  activeRole      Role    @default(OWNER)
  hasSelectedRole Boolean @default(true)

  city   GulfCity?
  locale String    @default("en") // "en" | "ar"

  referralCode String  @unique @default(cuid())
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("Referrals")

  isSuspended Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  caregiverProfile CaregiverProfile?
  pets             Pet[]
  bookingsAsOwner  Booking[]         @relation("OwnerBookings")
  reviewsWritten   Review[]          @relation("ReviewAuthor")
  reviewsReceived  Review[]          @relation("ReviewSubject")
  subscriptions    Subscription[]
  promoRedemptions PromoRedemption[]
  referralCredits  ReferralCredit[]  @relation("CreditOwner")
  notifications    Notification[]

  conversationsAsOwner     Conversation[] @relation("ConversationOwner")
  conversationsAsCaregiver Conversation[] @relation("ConversationCaregiver")
  messages                 Message[]

  @@index([email])
  @@index([activeRole])
}

// ---------------------------------------------------------------------------
// Caregiver profile, availability & verification
// ---------------------------------------------------------------------------

model CaregiverProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio             String?       @db.Text
  yearsExperience Int?
  city            GulfCity
  areas           String[] // neighborhoods, e.g. "Dubai Marina", "JLT"
  languages       Language[]
  services        ServiceType[]

  hourlyRate Decimal  @db.Decimal(10, 2)
  currency   Currency

  verificationStatus VerificationStatus @default(UNVERIFIED)
  backgroundChecked  Boolean            @default(false)
  idDocumentUrl      String?
  certificationUrls  String[]

  isProBadge      Boolean   @default(false) // Caregiver Pro subscription active
  isFeaturedUntil DateTime?
  isVacationMode  Boolean   @default(false)

  ratingAverage Decimal? @db.Decimal(3, 2)
  ratingCount   Int      @default(0)

  profileCompleteness Int @default(0) // 0-100, recomputed on save

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availabilitySlots     AvailabilitySlot[]
  availabilityOverrides AvailabilityOverride[]
  bookings              Booking[]
  featuredListings      FeaturedListing[]

  @@index([city])
  @@index([verificationStatus])
}

// Recurring weekly free slots, 30-minute granularity, 05:30–21:00.
// dayOfWeek: 0 = Sunday .. 6 = Saturday (Gulf week starts Sunday).
model AvailabilitySlot {
  id                 String           @id @default(cuid())
  caregiverProfileId String
  caregiverProfile   CaregiverProfile @relation(fields: [caregiverProfileId], references: [id], onDelete: Cascade)

  dayOfWeek   Int // 0-6
  startMinute Int // minutes since 00:00, e.g. 330 = 05:30

  createdAt DateTime @default(now())

  @@unique([caregiverProfileId, dayOfWeek, startMinute])
  @@index([caregiverProfileId, dayOfWeek])
}

// Date-specific overrides: a full day off, or vacation-mode block.
model AvailabilityOverride {
  id                 String           @id @default(cuid())
  caregiverProfileId String
  caregiverProfile   CaregiverProfile @relation(fields: [caregiverProfileId], references: [id], onDelete: Cascade)

  date     DateTime @db.Date
  isDayOff Boolean  @default(true)

  createdAt DateTime @default(now())

  @@unique([caregiverProfileId, date])
}

// ---------------------------------------------------------------------------
// Pets
// ---------------------------------------------------------------------------

model Pet {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name               String
  type               PetType
  breed              String?
  age                Int?
  temperament        String? @db.Text
  photoUrl           String?
  vaccinationCardUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([ownerId])
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("OwnerBookings", fields: [ownerId], references: [id], onDelete: Cascade)

  caregiverProfileId String
  caregiverProfile   CaregiverProfile @relation(fields: [caregiverProfileId], references: [id], onDelete: Cascade)

  petId String
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  serviceType ServiceType

  date            DateTime @db.Date
  startMinute     Int // minutes since 00:00
  durationMinutes Int // 30-180, multiples of 30

  hourlyRateSnapshot Decimal  @db.Decimal(10, 2)
  currency           Currency
  subtotal           Decimal  @db.Decimal(10, 2)
  serviceFee         Decimal  @default(0) @db.Decimal(10, 2)
  commissionRate     Decimal  @db.Decimal(5, 4) // e.g. 0.18
  commissionAmount   Decimal  @db.Decimal(10, 2)
  caregiverPayout    Decimal  @db.Decimal(10, 2)
  total              Decimal  @db.Decimal(10, 2)

  status    BookingStatus @default(REQUESTED)
  ownerNote String?       @db.Text

  isRecurring       Boolean @default(false)
  recurrenceGroupId String?

  paymentMethod         PaymentMethod?
  paymentStatus         PaymentStatus  @default(PENDING)
  stripePaymentIntentId String?

  respondByAt        DateTime? // accept/decline within 2 hours or auto-decline
  acceptedAt         DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  promoRedemptionId String?          @unique
  promoRedemption   PromoRedemption? @relation(fields: [promoRedemptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review       Review?
  photoUpdates BookingPhotoUpdate[]
  conversation Conversation?

  // A caregiver cannot have two overlapping bookings on the same date.
  @@unique([caregiverProfileId, date, startMinute])
  @@index([ownerId])
  @@index([caregiverProfileId, date])
  @@index([status])
}

// Photo/video updates a caregiver sends during an active booking.
model BookingPhotoUpdate {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  mediaUrl String
  caption  String?

  createdAt DateTime @default(now())

  @@index([bookingId])
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------

model Review {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  subjectId String
  subject   User   @relation("ReviewSubject", fields: [subjectId], references: [id], onDelete: Cascade)

  rating  Int // 1-5
  comment String? @db.Text

  createdAt DateTime @default(now())

  @@index([subjectId])
}

// ---------------------------------------------------------------------------
// In-app chat (owner <-> caregiver, phone numbers masked)
// ---------------------------------------------------------------------------

model Conversation {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  caregiverId String
  caregiver   User   @relation("ConversationCaregiver", fields: [caregiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  messages Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  body   String    @db.Text
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId])
}

// ---------------------------------------------------------------------------
// Monetization: subscriptions, promo codes, referrals, featured listings
// ---------------------------------------------------------------------------

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan
  status SubscriptionStatus @default(ACTIVE)

  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PromoCode {
  id          String  @id @default(cuid())
  code        String  @unique
  description String?

  percentOff     Int?
  fixedAmountOff Decimal?  @db.Decimal(10, 2)
  currency       Currency?

  maxRedemptions   Int?
  redemptionCount  Int     @default(0)
  firstBookingOnly Boolean @default(false)

  startsAt  DateTime?
  expiresAt DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  discountAmount Decimal  @db.Decimal(10, 2)
  currency       Currency

  createdAt DateTime @default(now())

  booking Booking?

  @@index([userId])
}

model ReferralCredit {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("CreditOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  amount   Decimal  @db.Decimal(10, 2)
  currency Currency

  reason     String // "REFERRAL_SIGNUP_COMPLETED_BOOKING"
  isRedeemed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ownerId])
}

model FeaturedListing {
  id                 String           @id @default(cuid())
  caregiverProfileId String
  caregiverProfile   CaregiverProfile @relation(fields: [caregiverProfileId], references: [id], onDelete: Cascade)

  startsAt   DateTime
  endsAt     DateTime
  amountPaid Decimal  @db.Decimal(10, 2)
  currency   Currency

  stripePaymentIntentId String?

  createdAt DateTime @default(now())

  @@index([caregiverProfileId])
}

// ---------------------------------------------------------------------------
// Platform configuration & notifications
// ---------------------------------------------------------------------------

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String // "BOOKING_REMINDER" | "CAREGIVER_ON_WAY" | "REVIEW_PROMPT" | "WIN_BACK" | ...
  title   String
  body    String    @db.Text
  channel String // "EMAIL" | "WHATSAPP" | "PUSH" | "IN_APP"
  sentAt  DateTime?
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}
