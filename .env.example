# =============================================================
# Agentic-OS Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ── Kimi K2.6 (Primary LLM) ──────────────────────────────────
KIMI_API_KEY=sk-your-kimi-api-key-here
# Kimi API base URL (do not change unless using a custom proxy)
KIMI_API_BASE=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# ── Binance Exchange ──────────────────────────────────────────
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
# Set to true for paper trading (testnet), false for live
BINANCE_TESTNET=true
BINANCE_TESTNET_API_KEY=your-binance-testnet-api-key
BINANCE_TESTNET_SECRET_KEY=your-binance-testnet-secret-key

# ── Trading Configuration ─────────────────────────────────────
# Comma-separated symbols, or AUTO3 to let the bot pick
TRADING_SYMBOL=BTCUSDT
# Leverage (1-20 recommended)
LEVERAGE=5
# Max position size as fraction of balance
MAX_POSITION_PCT=0.10

# ── Web Dashboard ─────────────────────────────────────────────
DASHBOARD_PASSWORD=admin
DASHBOARD_PORT=8000

# ── Optional: Redis (for caching) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank if no password
REDIS_PASSWORD=

# ── Hermes Agent Integration ──────────────────────────────────
# Hermes will use these same Kimi credentials via the skill config
HERMES_SKILL_SECRET=change-this-to-a-random-string

# ── Notifications (optional) ──────────────────────────────────
# Telegram bot token and chat ID for trade alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
