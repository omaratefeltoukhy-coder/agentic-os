DATABASE_URL="postgresql://user:password@localhost:5432/gulfpaws?schema=public"

# NextAuth / Auth.js
AUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (Resend) — used for verification links, OTP codes, booking notifications
RESEND_API_KEY=""
EMAIL_FROM="GulfPaws <noreply@gulfpaws.app>"

# Stripe — optional. Without these, card payments/subscriptions/featured
# listings fall back to Cash / a dev-mode direct activation so the app is
# fully testable without live keys.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cloudinary — optional, not wired up. Uploads use local disk storage
# (public/uploads) by default; see src/lib/upload.ts to swap providers.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
